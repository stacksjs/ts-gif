{
  "name": "ts-gif",
  "type": "module",
  "version": "0.1.2",
  "description": "TypeScript implementation of a performant GIF encoder & decoder.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-gif#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-gif.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-gif/issues"
  },
  "keywords": [
    "gif",
    "gif89a",
    "gif87a",
    "encoder",
    "decoder",
    "typescript",
    "ts-gif",
    "library"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build",
    "test": "bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bun --bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "release:patch": "bun --bun run changelog:generate && bunx --bun bumpx patch --yes",
    "release:minor": "bun --bun run changelog:generate && bunx --bun bumpx minor --yes",
    "release:major": "bun --bun run changelog:generate && bunx --bun bumpx major --yes",
    "postinstall": "bunx git-hooks",
    "dev:docs": "bun --bun bunpress dev docs",
    "build:docs": "bun --bun bunpress build docs",
    "preview:docs": "bun --bun bunpress preview docs",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write"
  },
  "dependencies": {
    "data-uri-to-buffer": "^8.0.0"
  },
  "devDependencies": {
    "@types/cwise-compiler": "^1.1.6",
    "cwise-compiler": "^1.1.3",
    "typescript": "^5.9.3",
    "better-dx": "^0.2.7"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
